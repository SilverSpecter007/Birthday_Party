---
import InvitationLayout from '../layouts/InvitationLayout.astro';
import { EVENT } from '../lib/config';
---
<InvitationLayout title={`${EVENT.title} – ${EVENT.hosts}`}>
  <div class="text-center space-y-8 pt-16 sm:pt-20 pb-8">
    <!-- Main heading -->
    <h1 class="glitter-text font-[var(--font-display)] text-5xl sm:text-6xl font-black leading-tight tracking-tight">
      Save the Date
    </h1>

    <!-- Subtitle -->
    <p class="text-lg sm:text-xl text-[var(--color-cream-light)] leading-relaxed">
      {EVENT.subtitle}
    </p>

    <!-- Event details -->
    <div class="space-y-2 text-[var(--color-cream-light)]">
      <p class="text-2xl sm:text-3xl font-[var(--font-display)] text-[var(--color-gold)]">
        Am {EVENT.date_short}
      </p>
      <p class="text-lg">
        in der <span class="font-semibold text-[var(--color-gold-light)]">{EVENT.location}</span>
      </p>
      {EVENT.time && <p class="text-lg">{EVENT.time}</p>}
      {EVENT.address && <p class="text-sm opacity-70">{EVENT.address}</p>}
    </div>

    <!-- Hosts signature -->
    <p class="font-[var(--font-script)] text-4xl sm:text-5xl text-[var(--color-gold)] pt-2">
      {EVENT.hosts}
    </p>

    <!-- Divider -->
    <div class="flex items-center justify-center gap-4 py-4">
      <div class="h-px w-16 bg-gradient-to-r from-transparent to-[var(--color-gold)]"></div>
      <div class="w-2 h-2 rounded-full bg-[var(--color-gold)] opacity-60"></div>
      <div class="h-px w-16 bg-gradient-to-l from-transparent to-[var(--color-gold)]"></div>
    </div>

  </div>
</InvitationLayout>
