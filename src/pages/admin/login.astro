---
import '../../styles/global.css';
import { signSession } from '../../middleware';
export const prerender = false;

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const password = formData.get('password')?.toString() || '';
  const adminPassword = import.meta.env.ADMIN_PASSWORD || 'default-change-me';

  if (password === adminPassword) {
    const sessionValue = signSession(Date.now());
    Astro.cookies.set('admin_session', sessionValue, {
      path: '/',
      httpOnly: true,
      sameSite: 'lax',
      maxAge: 60 * 60 * 24, // 24 hours
    });
    return Astro.redirect('/admin');
  } else {
    error = 'Falsches Passwort.';
  }
}
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin Login</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet" />
</head>
<body class="min-h-dvh bg-[var(--color-bg-dark)] flex items-center justify-center px-4"
  style="background-image: radial-gradient(ellipse at 30% 20%, rgba(120,102,170,0.12) 0%, transparent 55%), radial-gradient(ellipse at 70% 80%, rgba(204,158,130,0.08) 0%, transparent 55%);">
  <div class="w-full max-w-sm">
    <!-- Logo / heading -->
    <div class="text-center mb-8">
      <p class="font-[var(--font-script)] text-4xl text-[var(--color-gold)] mb-1">Janina & Julian</p>
      <p class="text-xs uppercase tracking-widest text-[var(--color-cream)] opacity-40">Gästeverwaltung</p>
    </div>

    <!-- Card -->
    <div class="admin-card">
      {error && (
        <div class="mb-5 px-4 py-3 bg-red-950/40 border border-red-500/25 rounded-lg text-red-300 text-sm text-center">
          {error}
        </div>
      )}

      <form method="POST" class="space-y-5">
        <div>
          <label for="password" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-cream)] opacity-60 mb-2">
            Passwort
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autofocus
            class="w-full px-4 py-3 bg-[var(--color-form-bg)] border border-[var(--color-form-border)] rounded-lg text-[var(--color-cream)] focus:outline-none focus:ring-2 focus:ring-[var(--color-gold)]/40 focus:border-[var(--color-gold)] transition-all placeholder:opacity-30"
            placeholder="••••••••"
          />
        </div>
        <button
          type="submit"
          class="w-full py-3 bg-[var(--color-gold)] text-[var(--color-bg-dark)] font-bold rounded-lg hover:bg-[var(--color-gold-light)] active:scale-[0.98] transition-all cursor-pointer"
        >
          Anmelden
        </button>
      </form>
    </div>
  </div>
</body>
</html>
