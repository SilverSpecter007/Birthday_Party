---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getInfoContent, updateInfoContent } from '../../lib/db';
export const prerender = false;

let saved = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const content = formData.get('content')?.toString() ?? '';
  await updateInfoContent(content);
  saved = true;
}

const content = await getInfoContent();
---
<AdminLayout title="Info-Seite bearbeiten">
  <div class="max-w-2xl mx-auto px-4 py-8">

    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="font-[var(--font-display)] text-2xl font-bold text-[var(--color-cream)]">
          Info-Seite
        </h1>
        <p class="text-sm text-[var(--color-cream)] opacity-50 mt-0.5">
          Wird auf <span class="text-[var(--color-gold)]">/info</span> angezeigt
        </p>
      </div>
      <a
        href="/info"
        target="_blank"
        class="text-xs uppercase tracking-wider text-[var(--color-gold)] opacity-70 hover:opacity-100 transition-opacity"
      >
        Vorschau ↗
      </a>
    </div>

    {saved && (
      <div class="mb-5 px-4 py-3 bg-green-950/40 border border-green-500/25 rounded-lg text-green-300 text-sm text-center success-flash">
        Gespeichert ✓
      </div>
    )}

    <div class="admin-card">
      <form method="POST" class="space-y-4">
        <div>
          <label for="content" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-cream)] opacity-60 mb-2">
            Inhalt
          </label>
          <textarea
            id="content"
            name="content"
            rows="12"
            class="w-full px-4 py-3 bg-[var(--color-form-bg)] border border-[var(--color-form-border)] rounded-lg text-[var(--color-cream)] focus:outline-none focus:ring-2 focus:ring-[var(--color-gold)]/40 focus:border-[var(--color-gold)] transition-all resize-y text-sm leading-relaxed"
            placeholder="Hier die Infos zur Party eintragen…"
          >{content}</textarea>
          <p class="text-xs text-[var(--color-cream)] opacity-35 mt-1.5">
            Zeilenumbrüche werden beibehalten.
          </p>
        </div>
        <button
          type="submit"
          class="w-full py-3 bg-[var(--color-gold)] text-[var(--color-bg-dark)] font-bold rounded-lg hover:bg-[var(--color-gold-light)] active:scale-[0.98] transition-all cursor-pointer"
        >
          Speichern
        </button>
      </form>
    </div>

  </div>
</AdminLayout>
