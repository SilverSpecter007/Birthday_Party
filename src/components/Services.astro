---

<section id="leistungen" class="section-padding bg-white">
  <div class="container-site">
    <div class="text-center mb-16 lg:mb-20 max-w-3xl mx-auto">
      <div class="gold-line mx-auto mb-5"></div>
      <h2 class="text-4xl md:text-5xl font-display font-bold text-salon-dark mb-5">
        Unsere Leistungen
      </h2>
      <p class="text-lg text-warm-500 leading-relaxed">
        Von einfachen bis aufwändigen Haarschnitten, tollen Haarfarben über trendige
        Strähnentechniken bis hin zu Hochsteckfrisuren – wir bieten Ihnen das volle Programm.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {services.map((service) => (
        <div class="group relative p-7 rounded-2xl bg-gradient-to-b from-salon-cream/80 to-white
                    border border-warm-100/80 hover:border-salon-gold/30
                    hover:shadow-xl hover:shadow-salon-gold/[0.08]
                    transition-all duration-500 hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-salon-gold/20 to-salon-gold/5
                      flex items-center justify-center mb-5
                      group-hover:from-salon-gold/30 group-hover:to-salon-gold/10 transition-all duration-300">
            <svg class="w-6 h-6 text-salon-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPaths[service.icon]} />
            </svg>
          </div>
          <h3 class="text-lg font-display font-semibold text-salon-dark mb-2.5">
            {service.title}
          </h3>
          <p class="text-warm-500 text-sm leading-relaxed mb-4">
            {service.description}
          </p>
          <div class="flex flex-wrap gap-1.5">
            {service.tags.map((tag) => (
              <span class="text-[10px] font-semibold uppercase tracking-wider text-salon-gold/80
                          bg-salon-gold/[0.08] rounded-full px-2.5 py-1">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-14 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://connect.shore.com/bookings/friseur-christina-aldag/services?locale=de"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold"
      >
        Alle Services & Preise ansehen
      </a>
      <a href="tel:+4941658833" class="btn-outline">
        Telefonisch beraten lassen
      </a>
    </div>
  </div>
</section>
