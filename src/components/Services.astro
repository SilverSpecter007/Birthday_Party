    icon: 'scissors',
    title: 'Schnitt & Styling',
    description: 'Individuelle Haarschnitte für Damen, Herren und Kinder – von klassisch bis trendig. Mit Waschen, Beratung und perfektem Finish.',
    tags: ['Damen', 'Herren', 'Kinder'],
  },
  {
    icon: 'color',
    title: 'Colorationen',
    description: 'Professionelle Haarfarben mit L\'Oréal Professionnel. Ob dezente Veränderung oder kompletter Farbwechsel – wir finden Ihren Ton.',
    tags: ['L\'Oréal', 'Glossing', 'Ansatz'],
  },
  {
    icon: 'balayage',
    title: 'Balayage & Strähnentechniken',
    description: 'Natürlich fließende Farbverläufe mit Balayage, Foilyage oder klassische Strähnentechniken für einen strahlenden Look.',
    tags: ['Balayage', 'Foilyage', 'Highlights'],
  },
  {
    icon: 'hot',
    title: 'Heiße Schere',
    description: 'Schonender Schnitt mit der heißen Schere – versiegelt die Haarspitzen und sorgt für gesundes, glänzendes Haar.',
    tags: ['Pflege', 'Versiegelung', 'Glanz'],
  },
  {
    icon: 'extensions',
    title: 'Haarverdichtung & Extensions',
    description: 'Mehr Fülle, Länge und Volumen mit hochwertigen Tressen. Für natürlich aussehendes, traumhaft schönes Haar.',
    tags: ['Tressen', 'Volumen', 'Länge'],
  },
  {
    icon: 'brow',
    title: 'Brow Lifting',
    description: 'Semi-permanentes Augenbrauen-Lifting für perfekt geformte, volle Brauen. Der Trend-Look für einen ausdrucksstarken Blick.',
    tags: ['Augenbrauen', 'Semi-permanent', 'Trend'],
  },
  {
    icon: 'updo',
    title: 'Hochsteckfrisuren',
    description: 'Elegante Hochsteckfrisuren für besondere Anlässe – Hochzeit, Abiball oder Gala. Individuell gestylt nach Ihren Wünschen.',
    tags: ['Hochzeit', 'Events', 'Styling'],
  },
  {
    icon: 'care',
    title: 'Pflege & Kur',
    description: 'Intensive Haarpflege mit Kevin Murphy Produkten. Tiefenwirksame Treatments für strapaziertes, trockenes oder coloriertes Haar.',
