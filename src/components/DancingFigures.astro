---
---
<div class="dancers-wrapper" aria-hidden="true">

  <!-- Dancer 1 — left, rosé gold, classic disco point pose -->
  <div class="dancer dancer-1">
    <svg viewBox="0 0 64 90" width="58" height="82" xmlns="http://www.w3.org/2000/svg">
      <g fill="none" stroke="#cc9e82" stroke-linecap="round" stroke-linejoin="round">
        <!-- head -->
        <circle cx="32" cy="10" r="9" fill="#cc9e82" stroke="none"/>
        <!-- torso (slightly angled, hip shifted) -->
        <path d="M32 19 Q30 34 28 48" stroke-width="7"/>
        <!-- right arm: raised high, elbow bend (disco point) -->
        <line x1="31" y1="28" x2="50" y2="17" stroke-width="5"/>
        <line x1="50" y1="17" x2="57" y2="5"  stroke-width="4"/>
        <!-- left arm: down and out -->
        <line x1="31" y1="28" x2="13" y2="40" stroke-width="5"/>
        <line x1="13" y1="40" x2="8"  y2="50" stroke-width="4"/>
        <!-- left leg -->
        <line x1="28" y1="48" x2="18" y2="76" stroke-width="6"/>
        <line x1="18" y1="76" x2="12" y2="86" stroke-width="5"/>
        <!-- right leg (angled out, foot turned) -->
        <line x1="28" y1="48" x2="40" y2="72" stroke-width="6"/>
        <line x1="40" y1="72" x2="48" y2="80" stroke-width="5"/>
      </g>
    </svg>
  </div>

  <!-- Dancer 2 — right, violet, both arms raised celebration pose -->
  <div class="dancer dancer-2">
    <svg viewBox="0 0 64 90" width="58" height="82" xmlns="http://www.w3.org/2000/svg">
      <g fill="none" stroke="#b8a8e0" stroke-linecap="round" stroke-linejoin="round">
        <!-- head -->
        <circle cx="32" cy="10" r="9" fill="#b8a8e0" stroke="none"/>
        <!-- torso -->
        <path d="M32 19 Q34 34 33 48" stroke-width="7"/>
        <!-- left arm raised -->
        <line x1="32" y1="27" x2="14" y2="14" stroke-width="5"/>
        <line x1="14" y1="14" x2="8"  y2="4"  stroke-width="4"/>
        <!-- right arm raised -->
        <line x1="32" y1="27" x2="50" y2="14" stroke-width="5"/>
        <line x1="50" y1="14" x2="56" y2="4"  stroke-width="4"/>
        <!-- left leg -->
        <line x1="33" y1="48" x2="20" y2="74" stroke-width="6"/>
        <line x1="20" y1="74" x2="14" y2="84" stroke-width="5"/>
        <!-- right leg -->
        <line x1="33" y1="48" x2="44" y2="72" stroke-width="6"/>
        <line x1="44" y1="72" x2="52" y2="80" stroke-width="5"/>
      </g>
    </svg>
  </div>

</div>

<style>
  .dancers-wrapper {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    pointer-events: none;
    z-index: 3;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 0 1rem;
  }

  .dancer {
    opacity: 0.72;
    transform-origin: bottom center;
  }

  .dancer-1 {
    filter: drop-shadow(0 0 10px rgba(204, 158, 130, 0.45));
    animation: dance-1 1.1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .dancer-2 {
    filter: drop-shadow(0 0 10px rgba(184, 168, 224, 0.50));
    animation: dance-2 1.1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    animation-delay: 0.55s;
  }

  @keyframes dance-1 {
    0%, 100% { transform: rotate(-6deg) translateY(0px); }
    50%       { transform: rotate(4deg)  translateY(-10px); }
  }

  @keyframes dance-2 {
    0%, 100% { transform: rotate(5deg)  translateY(-6px); }
    50%       { transform: rotate(-6deg) translateY(4px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .dancer-1, .dancer-2 { animation: none; }
  }
</style>
