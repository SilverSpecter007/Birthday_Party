---
---
<div class="disco-ball-wrapper" aria-hidden="true">
  <!-- Hanging wire -->
  <div class="disco-string"></div>

  <!-- Swaying container -->
  <div class="disco-sway">
    <!-- Ball (rotating) -->
    <div class="disco-ball-inner">
      <svg viewBox="0 0 110 110" width="72" height="72" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- Mirror tile grid: 5×5 cells, 4px tile + 1px gap (fine!) -->
          <pattern id="mirror-tiles" x="0" y="0" width="5" height="5" patternUnits="userSpaceOnUse">
            <rect width="5" height="5" fill="#12101e" />
            <rect x="0.5" y="0.5" width="4" height="4" fill="#b2aac0" rx="0.15" />
          </pattern>

          <!-- Sphere clip -->
          <clipPath id="ball-clip">
            <circle cx="55" cy="55" r="49" />
          </clipPath>

          <!-- 3D shading: dark at edges, open at top-left -->
          <radialGradient id="sphere-shade" cx="36%" cy="30%" r="68%" gradientUnits="objectBoundingBox">
            <stop offset="0%"   stop-color="rgba(255,248,244,0.0)" />
            <stop offset="42%"  stop-color="rgba(80,60,90,0.50)" />
            <stop offset="100%" stop-color="rgba(8,6,18,0.92)" />
          </radialGradient>

          <!-- Primary specular (bright white spot) -->
          <radialGradient id="spec1" cx="33%" cy="27%" r="32%" gradientUnits="objectBoundingBox">
            <stop offset="0%"   stop-color="rgba(255,255,255,0.98)" />
            <stop offset="45%"  stop-color="rgba(255,248,240,0.30)" />
            <stop offset="100%" stop-color="transparent" />
          </radialGradient>

          <!-- Secondary warm glow (bottom-right) -->
          <radialGradient id="spec2" cx="67%" cy="70%" r="35%" gradientUnits="objectBoundingBox">
            <stop offset="0%"   stop-color="rgba(204,158,130,0.22)" />
            <stop offset="100%" stop-color="transparent" />
          </radialGradient>

          <!-- Outer glow filter -->
          <filter id="ball-glow" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur" />
            <feColorMatrix in="blur" type="matrix"
              values="1 0.3 0.2 0 0  0.5 0.2 0.5 0 0  0.3 0.1 0.8 0 0  0 0 0 0.6 0"
              result="tinted" />
            <feMerge>
              <feMergeNode in="tinted" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>

        <!-- Outer glow ring -->
        <circle cx="55" cy="55" r="52" fill="none"
          stroke="rgba(120,102,170,0.18)" stroke-width="4" filter="url(#ball-glow)" />

        <!-- Base dark sphere -->
        <circle cx="55" cy="55" r="49" fill="#16142a" />

        <!-- Mirror tiles -->
        <rect x="6" y="6" width="98" height="98"
          fill="url(#mirror-tiles)" clip-path="url(#ball-clip)" />

        <!-- 3D shading over tiles -->
        <circle cx="55" cy="55" r="49" fill="url(#sphere-shade)" />

        <!-- Bright flash tiles — aligned to 5px grid, each = 1 tile (4×4) -->
        <g clip-path="url(#ball-clip)">
          <!-- Bright white/silver flashes -->
          <rect x="25.5" y="25.5" width="4" height="4" fill="rgba(255,252,248,0.95)" rx="0.15" />
          <rect x="50.5" y="15.5" width="4" height="4" fill="rgba(255,250,245,0.90)" rx="0.15" />
          <rect x="35.5" y="45.5" width="4" height="4" fill="rgba(255,248,242,0.85)" rx="0.15" />
          <rect x="70.5" y="35.5" width="4" height="4" fill="rgba(245,230,218,0.80)" rx="0.15" />
          <rect x="15.5" y="50.5" width="4" height="4" fill="rgba(255,248,242,0.82)" rx="0.15" />
          <rect x="80.5" y="50.5" width="4" height="4" fill="rgba(238,222,210,0.75)" rx="0.15" />
          <rect x="40.5" y="60.5" width="4" height="4" fill="rgba(255,245,238,0.78)" rx="0.15" />
          <rect x="60.5" y="70.5" width="4" height="4" fill="rgba(255,245,235,0.72)" rx="0.15" />
          <rect x="30.5" y="75.5" width="4" height="4" fill="rgba(255,248,242,0.65)" rx="0.15" />
          <rect x="20.5" y="35.5" width="4" height="4" fill="rgba(245,235,225,0.70)" rx="0.15" />
          <rect x="75.5" y="25.5" width="4" height="4" fill="rgba(238,228,218,0.68)" rx="0.15" />
          <rect x="55.5" y="85.5" width="4" height="4" fill="rgba(255,248,240,0.55)" rx="0.15" />
          <!-- Rosé gold flashes -->
          <rect x="60.5" y="25.5" width="4" height="4" fill="rgba(204,158,130,0.70)" rx="0.15" />
          <rect x="80.5" y="70.5" width="4" height="4" fill="rgba(204,158,130,0.60)" rx="0.15" />
          <rect x="25.5" y="70.5" width="4" height="4" fill="rgba(204,158,130,0.55)" rx="0.15" />
          <rect x="45.5" y="20.5" width="4" height="4" fill="rgba(221,184,158,0.60)" rx="0.15" />
          <!-- Violet flashes -->
          <rect x="85.5" y="45.5" width="4" height="4" fill="rgba(180,160,220,0.58)" rx="0.15" />
          <rect x="15.5" y="65.5" width="4" height="4" fill="rgba(180,160,220,0.52)" rx="0.15" />
          <rect x="50.5" y="80.5" width="4" height="4" fill="rgba(160,140,210,0.48)" rx="0.15" />
          <rect x="70.5" y="55.5" width="4" height="4" fill="rgba(190,170,230,0.45)" rx="0.15" />
        </g>

        <!-- Specular highlights on top -->
        <circle cx="55" cy="55" r="49" fill="url(#spec1)" />
        <circle cx="55" cy="55" r="49" fill="url(#spec2)" />

        <!-- Top mounting cap -->
        <ellipse cx="55" cy="9" rx="5" ry="3"
          fill="#1e1c32" stroke="rgba(180,160,140,0.35)" stroke-width="0.5" />
      </svg>
    </div>

    <!-- Scattered light reflections -->
    <div class="refl r1"></div>
    <div class="refl r2"></div>
    <div class="refl r3"></div>
    <div class="refl r4"></div>
    <div class="refl r5"></div>
    <div class="refl r6"></div>
    <div class="refl r7"></div>
  </div>
</div>

<style>
  .disco-ball-wrapper {
    position: absolute;
    top: -10px;
    right: 0.5rem;
    z-index: 10;
    pointer-events: none;
  }

  .disco-string {
    width: 1.5px;
    height: 32px;
    margin: 0 auto;
    background: linear-gradient(
      to bottom,
      rgba(180, 160, 150, 0.15),
      rgba(180, 160, 140, 0.55)
    );
  }

  .disco-sway {
    position: relative;
    transform-origin: top center;
    animation: disco-sway 5s ease-in-out infinite;
  }

  .disco-ball-inner {
    display: flex;
    justify-content: center;
    animation: disco-rotate 12s linear infinite;
    filter:
      drop-shadow(0 0 14px rgba(204, 158, 130, 0.30))
      drop-shadow(0 0 32px rgba(120, 102, 170, 0.20));
  }

  /* Scattered light dots */
  .refl {
    position: absolute;
    border-radius: 50%;
    animation: twinkle var(--dur, 2s) ease-in-out infinite;
    animation-delay: var(--del, 0s);
    pointer-events: none;
  }

  /* White/warm reflections */
  .r1 {
    width: 5px; height: 5px;
    background: rgba(255, 245, 235, 0.95);
    box-shadow: 0 0 5px 2px rgba(255, 220, 190, 0.70);
    top: 12px; left: -22px;
    --dur: 1.7s; --del: 0s;
  }
  .r2 {
    width: 4px; height: 4px;
    background: rgba(255, 250, 248, 0.90);
    box-shadow: 0 0 4px 2px rgba(240, 210, 190, 0.60);
    top: 40px; right: -24px;
    --dur: 2.4s; --del: 0.55s;
  }
  .r3 {
    width: 3px; height: 3px;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 0 3px 2px rgba(230, 200, 220, 0.65);
    top: 62px; left: -19px;
    --dur: 1.5s; --del: 1.1s;
  }
  /* Rosé gold reflections */
  .r4 {
    width: 5px; height: 5px;
    background: rgba(210, 165, 135, 0.95);
    box-shadow: 0 0 6px 2px rgba(204, 158, 130, 0.55);
    bottom: 22px; right: -18px;
    --dur: 2.9s; --del: 0.3s;
  }
  .r5 {
    width: 3px; height: 3px;
    background: rgba(220, 175, 148, 0.90);
    box-shadow: 0 0 4px 1px rgba(204, 158, 130, 0.50);
    bottom: 48px; left: -26px;
    --dur: 2.1s; --del: 1.6s;
  }
  /* Violet reflections */
  .r6 {
    width: 4px; height: 4px;
    background: rgba(190, 170, 230, 0.90);
    box-shadow: 0 0 5px 2px rgba(160, 140, 210, 0.55);
    top: 8px; right: -16px;
    --dur: 3.3s; --del: 0.85s;
  }
  .r7 {
    width: 3px; height: 3px;
    background: rgba(180, 160, 220, 0.85);
    box-shadow: 0 0 3px 2px rgba(150, 130, 200, 0.50);
    bottom: 10px; left: -14px;
    --dur: 1.9s; --del: 2.0s;
  }

  @media (max-width: 640px) {
    .disco-ball-wrapper { right: 0.25rem; }
    .disco-ball-inner svg { width: 56px; height: 56px; }
  }
</style>
