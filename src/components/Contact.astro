---
const hours = [
  { day: 'Montag', time: 'Geschlossen', closed: true },
  { day: 'Dienstag', time: '09:00 \u2013 19:00 Uhr', closed: false },
  { day: 'Mittwoch', time: '09:00 \u2013 19:00 Uhr', closed: false },
  { day: 'Donnerstag', time: '09:00 \u2013 19:00 Uhr', closed: false },
  { day: 'Freitag', time: '09:00 \u2013 19:00 Uhr', closed: false },
  { day: 'Samstag', time: '08:00 \u2013 13:00 Uhr', closed: false },
  { day: 'Sonntag', time: 'Geschlossen', closed: true },
];
---

<section id="oeffnungszeiten" class="section-padding bg-white">
  <div class="container-narrow">
    <div class="grid lg:grid-cols-2 gap-16">
      <!-- Opening Hours -->
      <div>
        <div class="decorative-line mb-4"></div>
        <h2 class="text-4xl md:text-5xl font-display font-semibold text-salon-dark mb-6">
          &Ouml;ffnungszeiten
        </h2>
        <p class="text-lg text-warm-500 mb-10">
          Wir arbeiten haupts&auml;chlich auf Terminbasis. Buchen Sie Ihren Termin
          bequem online oder rufen Sie uns an.
        </p>

        <div class="space-y-0">
          {hours.map((item) => (
            <div class={`flex justify-between items-center py-4 border-b border-warm-100
                        ${item.closed ? 'opacity-50' : ''}`}>
              <span class="font-medium text-salon-dark">{item.day}</span>
              <span class={`text-sm ${item.closed ? 'text-warm-400' : 'text-warm-600'}`}>
                {item.time}
              </span>
            </div>
          ))}
        </div>

        <div class="mt-8">
          <a
            href="https://connect.shore.com/bookings/friseur-christina-aldag/services?locale=de"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Online Termin buchen
          </a>
        </div>
      </div>

      <!-- Contact & Map -->
      <div id="kontakt">
        <div class="decorative-line mb-4"></div>
        <h2 class="text-4xl md:text-5xl font-display font-semibold text-salon-dark mb-6">
          Kontakt
        </h2>

        <div class="space-y-6 mb-10">
          <!-- Address -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-salon-gold/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-salon-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-medium text-salon-dark">Adresse</p>
              <p class="text-warm-500">Jahnstra&szlig;e 3<br />21279 Hollenstedt</p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-salon-gold/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-salon-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="font-medium text-salon-dark">Telefon</p>
              <a href="tel:+4941658833" class="text-warm-500 hover:text-salon-gold transition-colors">
                04165 / 88 33
              </a>
            </div>
          </div>

          <!-- Website -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-salon-gold/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-salon-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
              </svg>
            </div>
            <div>
              <p class="font-medium text-salon-dark">Online</p>
              <a href="https://www.instagram.com/salon_dueball_hollenstedt/"
                 target="_blank" rel="noopener noreferrer"
                 class="text-warm-500 hover:text-salon-gold transition-colors">
                @salon_dueball_hollenstedt
              </a>
            </div>
          </div>

          <!-- Payment -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-salon-gold/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-salon-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
              </svg>
            </div>
            <div>
              <p class="font-medium text-salon-dark">Bezahlung</p>
              <p class="text-warm-500">Bar, EC-Cash, Visa, Mastercard, Gutschein</p>
            </div>
          </div>
        </div>

        <!-- Map Embed -->
        <div class="rounded-2xl overflow-hidden border border-warm-100 shadow-sm">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2391.5!2d9.7098!3d53.3647!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47b1e8b6e2a4d5c7%3A0x4b2a8d7f6c8e9d0a!2sJahnstra%C3%9Fe+3%2C+21279+Hollenstedt!5e0!3m2!1sde!2sde!4v1700000000000!5m2!1sde!2sde"
            width="100%"
            height="300"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Salon Dueball - Standort auf Google Maps"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
