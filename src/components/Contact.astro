---
const hours = [
  { day: 'Montag', time: 'Geschlossen', closed: true },
  { day: 'Dienstag', time: '08:00 – 18:00 Uhr', closed: false },
  { day: 'Mittwoch', time: '09:00 – 19:00 Uhr', closed: false },
  { day: 'Donnerstag', time: '08:00 – 18:00 Uhr', closed: false },
  { day: 'Freitag', time: '08:00 – 18:00 Uhr', closed: false },
  { day: 'Samstag', time: '08:00 – 13:00 Uhr', closed: false },
  { day: 'Sonntag', time: 'Geschlossen', closed: true },
];
---

<section id="oeffnungszeiten" class="section-padding bg-white">
  <div class="container-site">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20">
      <!-- Opening Hours -->
      <div>
        <div class="gold-line mb-5"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-salon-dark mb-4">
          Öffnungszeiten
        </h2>
        <p class="text-lg text-warm-500 mb-10 leading-relaxed">
          Wir arbeiten hauptsächlich auf Terminbasis.
          Buchen Sie bequem online oder rufen Sie uns an.
        </p>

        <div class="bg-salon-cream/60 rounded-2xl p-6 border border-warm-100/60">
          {hours.map((item, i) => (
            <div class={`flex justify-between items-center py-3.5
                        ${i < hours.length - 1 ? 'border-b border-warm-100/60' : ''}
                        ${item.closed ? 'opacity-40' : ''}`}>
              <span class="font-medium text-salon-dark text-[15px]">{item.day}</span>
              <span class={`text-sm font-medium ${item.closed ? 'text-warm-400' : 'text-salon-gold'}`}>
                {item.time}
              </span>
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a
            href="https://connect.shore.com/bookings/friseur-christina-aldag/services?locale=de"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-gold"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Online buchen
          </a>
          <a href="tel:+4941658833" class="btn-outline">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            04165 / 88 33
          </a>
        </div>
      </div>

      <!-- Contact -->
      <div id="kontakt">
        <div class="gold-line mb-5"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-salon-dark mb-8">
          Kontakt
        </h2>

        <div class="space-y-5 mb-10">
          <a href="https://maps.google.com/?q=Jahnstraße+3,+21279+Hollenstedt" target="_blank" rel="noopener noreferrer"
             class="flex items-start gap-4 group p-4 rounded-xl hover:bg-salon-cream/60 transition-colors">
            <div class="w-11 h-11 rounded-xl bg-salon-gold/10 flex items-center justify-center flex-shrink-0
                        group-hover:bg-salon-gold/20 transition-colors">
              <svg class="w-5 h-5 text-salon-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-salon-dark text-sm">Adresse</p>
              <p class="text-warm-500 text-[15px]">Jahnstraße 3, 21279 Hollenstedt</p>
            </div>
          </a>

          <a href="tel:+4941658833" class="flex items-start gap-4 group p-4 rounded-xl hover:bg-salon-cream/60 transition-colors">
            <div class="w-11 h-11 rounded-xl bg-salon-gold/10 flex items-center justify-center flex-shrink-0
                        group-hover:bg-salon-gold/20 transition-colors">
              <svg class="w-5 h-5 text-salon-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-salon-dark text-sm">Telefon</p>
              <p class="text-warm-500 text-[15px]">04165 / 88 33</p>
            </div>
          </a>

          <a href="mailto:salon.dueball@gmail.com" class="flex items-start gap-4 group p-4 rounded-xl hover:bg-salon-cream/60 transition-colors">
            <div class="w-11 h-11 rounded-xl bg-salon-gold/10 flex items-center justify-center flex-shrink-0
                        group-hover:bg-salon-gold/20 transition-colors">
              <svg class="w-5 h-5 text-salon-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-salon-dark text-sm">E-Mail</p>
              <p class="text-warm-500 text-[15px]">salon.dueball@gmail.com</p>
            </div>
          </a>

          <div class="flex items-start gap-4 p-4">
            <div class="w-11 h-11 rounded-xl bg-salon-gold/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-salon-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-salon-dark text-sm">Bezahlung</p>
              <p class="text-warm-500 text-[15px]">Bar, EC-Cash, Visa, Mastercard, Gutschein</p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4">
            <div class="w-11 h-11 rounded-xl bg-salon-gold/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-salon-gold" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-salon-dark text-sm">Social Media</p>
              <div class="flex gap-3 mt-1">
                <a href="https://www.instagram.com/salon_dueball_hollenstedt/" target="_blank" rel="noopener noreferrer"
                   class="text-warm-500 hover:text-salon-gold transition-colors text-[15px]">Instagram</a>
                <span class="text-warm-300">·</span>
                <a href="https://www.facebook.com/salon.dueball/" target="_blank" rel="noopener noreferrer"
                   class="text-warm-500 hover:text-salon-gold transition-colors text-[15px]">Facebook</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="rounded-2xl overflow-hidden border border-warm-100 shadow-lg shadow-warm-100/30">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2391.5!2d9.7098!3d53.3647!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47b1e8b6e2a4d5c7%3A0x4b2a8d7f6c8e9d0a!2sJahnstra%C3%9Fe+3%2C+21279+Hollenstedt!5e0!3m2!1sde!2sde!4v1700000000000!5m2!1sde!2sde"
            width="100%"
            height="280"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Salon Dueball Standort – Jahnstraße 3, 21279 Hollenstedt"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
