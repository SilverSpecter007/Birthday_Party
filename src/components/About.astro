---
---

<section id="ueber-uns" class="section-padding">
  <div class="container-narrow">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Image / Visual -->
      <div class="relative">
        <div class="aspect-[4/5] rounded-3xl bg-gradient-to-br from-warm-200 via-warm-100 to-salon-cream
                    border border-warm-200 overflow-hidden shadow-lg">
          <div class="absolute inset-0 flex items-center justify-center p-12">
            <div class="text-center space-y-8">
              <div class="w-32 h-32 mx-auto rounded-full bg-salon-gold/15 flex items-center justify-center">
                <span class="font-display text-5xl font-semibold text-salon-gold">A</span>
              </div>
              <div class="space-y-2">
                <p class="font-display text-2xl font-semibold text-salon-dark">
                  Annika Dueball
                </p>
                <p class="text-warm-500 font-medium">
                  Inhaberin & Friseurmeisterin
                </p>
              </div>
              <div class="w-12 h-0.5 bg-salon-gold mx-auto"></div>
              <p class="text-warm-400 italic font-display text-lg">
                &bdquo;Jedes Haar erz&auml;hlt eine Geschichte &ndash;<br />
                wir helfen Ihnen, sie zu schreiben.&ldquo;
              </p>
            </div>
          </div>
        </div>
        <!-- Decorative element -->
        <div class="absolute -bottom-6 -right-6 w-48 h-48 rounded-2xl bg-salon-gold/10 -z-10"></div>
      </div>

      <!-- Text Content -->
      <div class="space-y-8">
        <div>
          <div class="decorative-line mb-4"></div>
          <h2 class="text-4xl md:text-5xl font-display font-semibold text-salon-dark mb-6">
            &Uuml;ber uns
          </h2>
        </div>

        <div class="space-y-5 text-warm-600 text-lg leading-relaxed">
          <p>
            Seit <strong class="text-salon-dark">2013</strong> f&uuml;hrt Annika Dueball als
            Inhaberin und Friseurmeisterin den Salon in der Jahnstra&szlig;e&nbsp;3 in Hollenstedt.
            Was einst als &bdquo;Friseur Christina Aldag&ldquo; bekannt war, ist heute der
            <strong class="text-salon-dark">Salon Dueball</strong> &ndash; alt bekannt und neu benannt.
          </p>
          <p>
            Im Sommer 2023 wurde der Salon komplett renoviert und erstrahlt seitdem in neuem Glanz.
            In moderner, einladender Atmosph&auml;re bieten wir Ihnen kreative Stylings, professionelle
            Colorationen und pers&ouml;nliche Beratung auf h&ouml;chstem Niveau.
          </p>
          <p>
            Unser Team arbeitet mit hochwertigen Produkten von
            <strong class="text-salon-dark">L'Or&eacute;al Professionnel</strong> und
            <strong class="text-salon-dark">Kevin Murphy</strong>, um f&uuml;r jedes Haar die
            perfekte Pflege und das ideale Styling zu finden.
          </p>
        </div>

        <!-- Highlights -->
        <div class="grid grid-cols-2 gap-6 pt-4">
          <div class="space-y-2">
            <p class="text-3xl font-display font-semibold text-salon-gold">10+</p>
            <p class="text-warm-500 text-sm font-medium">Jahre Erfahrung</p>
          </div>
          <div class="space-y-2">
            <p class="text-3xl font-display font-semibold text-salon-gold">2023</p>
            <p class="text-warm-500 text-sm font-medium">Komplett renoviert</p>
          </div>
          <div class="space-y-2">
            <p class="text-3xl font-display font-semibold text-salon-gold">L'Or&eacute;al</p>
            <p class="text-warm-500 text-sm font-medium">Professionelle Produkte</p>
          </div>
          <div class="space-y-2">
            <p class="text-3xl font-display font-semibold text-salon-gold">Top</p>
            <p class="text-warm-500 text-sm font-medium">Meisterbetrieb</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
