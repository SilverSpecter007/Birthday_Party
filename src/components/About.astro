---
---

<section id="ueber-uns" class="section-padding overflow-hidden">
  <div class="container-site">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">
      <!-- Visual Side -->
      <div class="relative">
        <div class="aspect-[4/5] rounded-3xl bg-gradient-to-br from-warm-200 via-warm-100 to-salon-cream
                    border border-warm-200/60 overflow-hidden shadow-xl shadow-warm-200/30">
          <div class="absolute inset-0 flex flex-col items-center justify-center p-10 text-center">
            <div class="w-28 h-28 rounded-full bg-gradient-to-br from-salon-gold/25 to-salon-gold/10
                        flex items-center justify-center mb-6 shadow-lg shadow-salon-gold/10">
              <span class="font-display text-5xl font-bold text-salon-gold">A</span>
            </div>
            <p class="font-display text-2xl font-bold text-salon-dark mb-1">Annika Dueball</p>
            <p class="text-warm-500 font-medium text-sm mb-6">Inhaberin & Friseurmeisterin</p>
            <div class="w-12 h-[2px] bg-gradient-to-r from-salon-gold to-salon-gold/30 mb-6"></div>
            <blockquote class="text-warm-500 italic font-display text-lg leading-relaxed max-w-xs">
              „Wir verstehen unser Handwerk und Ihre Wünsche – Wir können zuhören und lassen Sie gut aussehen."
            </blockquote>
          </div>
        </div>
        <!-- Decorative elements -->
        <div class="absolute -bottom-6 -right-6 w-48 h-48 rounded-3xl bg-salon-gold/[0.07] -z-10"></div>
        <div class="absolute -top-4 -left-4 w-24 h-24 rounded-full bg-salon-rose/10 -z-10 blur-sm"></div>
      </div>

      <!-- Text Side -->
      <div class="space-y-8">
        <div>
          <div class="gold-line mb-5"></div>
          <h2 class="text-4xl md:text-5xl font-display font-bold text-salon-dark mb-2">
            Über uns
          </h2>
          <p class="text-salon-gold font-display italic text-lg">Alt bekannt – und neu benannt!</p>
        </div>

        <div class="space-y-5 text-warm-600 text-[17px] leading-relaxed">
          <p>
            Seit <strong class="text-salon-dark font-semibold">2013</strong> führt Annika Dueball als
            Inhaberin und Friseurmeisterin den Salon in der Jahnstraße&nbsp;3 in Hollenstedt.
            Was einst als „Friseur Christina Aldag" bekannt war, ist heute der
            <strong class="text-salon-dark font-semibold">Salon Dueball</strong>.
          </p>
          <p>
            Im <strong class="text-salon-dark font-semibold">Sommer 2023</strong> wurde der Salon komplett
            renoviert und erstrahlt seitdem in neuem Glanz. In moderner, einladender Atmosphäre vereinen
            wir Stil und Gemütlichkeit – und bieten exzellenten Service auf höchstem Niveau.
          </p>
          <p>
            Unser Engagement für Nachhaltigkeit und Qualität spiegelt sich in jedem Detail wider.
            Wir arbeiten mit hochwertigen Produkten von
            <strong class="text-salon-dark font-semibold">L'Oréal Professionnel</strong> und
            <strong class="text-salon-dark font-semibold">Kevin Murphy</strong>, um für jedes Haar
            die perfekte Pflege zu finden.
          </p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-warm-100">
          <div class="text-center">
            <p class="text-3xl lg:text-4xl font-display font-bold text-salon-gold">10+</p>
            <p class="text-warm-500 text-xs font-semibold uppercase tracking-wider mt-1">Jahre</p>
          </div>
          <div class="text-center">
            <p class="text-3xl lg:text-4xl font-display font-bold text-salon-gold">2023</p>
            <p class="text-warm-500 text-xs font-semibold uppercase tracking-wider mt-1">Renoviert</p>
          </div>
          <div class="text-center">
            <p class="text-3xl lg:text-4xl font-display font-bold text-salon-gold">94%</p>
            <p class="text-warm-500 text-xs font-semibold uppercase tracking-wider mt-1">Empfehlen uns</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
