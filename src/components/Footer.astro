---
const currentYear = new Date().getFullYear();
---

<footer class="bg-salon-dark text-warm-400">
  <div class="container-site px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      <!-- Brand -->
      <div class="lg:col-span-2 space-y-5">
        <div class="flex items-center gap-3">
          <div class="relative w-10 h-10 rounded-full bg-salon-gold/20 flex items-center justify-center">
            <span class="text-salon-gold font-display text-sm font-bold">SD</span>
            <div class="absolute inset-0 rounded-full border border-salon-gold/20"></div>
          </div>
          <div>
            <span class="font-display text-lg font-semibold text-white block leading-tight">Salon Dueball</span>
            <span class="text-[10px] tracking-[0.15em] uppercase text-warm-600">Friseur in Hollenstedt</span>
          </div>
        </div>
        <p class="text-warm-500 max-w-sm leading-relaxed text-[15px]">
          Ihr Friseurmeisterbetrieb in Hollenstedt. Kreative Stylings, professionelle Colorationen
          und persönliche Beratung seit 2013.
        </p>
        <div class="flex gap-3 pt-1">
          <a href="https://www.instagram.com/salon_dueball_hollenstedt/" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 rounded-full bg-white/[0.06] flex items-center justify-center hover:bg-salon-gold/20 hover:text-salon-gold transition-all duration-300" aria-label="Instagram">
            <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.facebook.com/salon.dueball/" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 rounded-full bg-white/[0.06] flex items-center justify-center hover:bg-salon-gold/20 hover:text-salon-gold transition-all duration-300" aria-label="Facebook">
            <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="tel:+4941658833"
             class="w-10 h-10 rounded-full bg-white/[0.06] flex items-center justify-center hover:bg-salon-gold/20 hover:text-salon-gold transition-all duration-300" aria-label="Anrufen">
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-display font-semibold text-white text-sm uppercase tracking-wider mb-5">Navigation</h3>
        <ul class="space-y-3 text-[15px]">
          <li><a href="/#leistungen" class="hover:text-salon-gold transition-colors duration-300">Leistungen</a></li>
          <li><a href="/#ueber-uns" class="hover:text-salon-gold transition-colors duration-300">Über uns</a></li>
          <li><a href="/#team" class="hover:text-salon-gold transition-colors duration-300">Team</a></li>
          <li><a href="/#oeffnungszeiten" class="hover:text-salon-gold transition-colors duration-300">Öffnungszeiten</a></li>
          <li><a href="/#kontakt" class="hover:text-salon-gold transition-colors duration-300">Kontakt</a></li>
          <li><a href="/jobs" class="hover:text-salon-gold transition-colors duration-300">Jobs</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display font-semibold text-white text-sm uppercase tracking-wider mb-5">Kontakt</h3>
        <ul class="space-y-3 text-[15px]">
          <li>Jahnstraße 3</li>
          <li>21279 Hollenstedt</li>
          <li><a href="tel:+4941658833" class="hover:text-salon-gold transition-colors">04165 / 88 33</a></li>
          <li><a href="mailto:salon.dueball@gmail.com" class="hover:text-salon-gold transition-colors break-all">salon.dueball@gmail.com</a></li>
          <li class="pt-3">
            <a href="https://connect.shore.com/bookings/friseur-christina-aldag/services?locale=de"
               target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 text-salon-gold hover:text-white transition-colors font-medium">
              Online buchen
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/[0.06]">
    <div class="container-site px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-warm-600">
        <p>&copy; {currentYear} Salon Dueball. Alle Rechte vorbehalten.</p>
        <div class="flex gap-6">
          <a href="/impressum" class="hover:text-warm-400 transition-colors">Impressum</a>
          <a href="/datenschutz" class="hover:text-warm-400 transition-colors">Datenschutz</a>
          <a href="/agb" class="hover:text-warm-400 transition-colors">AGB</a>
        </div>
      </div>
    </div>
  </div>
</footer>
