---
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background with gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-warm-100 via-salon-cream to-warm-50"></div>

  <!-- Decorative elements -->
  <div class="absolute top-20 right-0 w-96 h-96 bg-salon-gold/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-salon-rose/10 rounded-full blur-3xl"></div>
  <div class="absolute top-1/3 left-1/4 w-64 h-64 bg-salon-sage/5 rounded-full blur-2xl"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 md:py-40">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Text Content -->
      <div class="space-y-8">
        <div class="space-y-2 animate-fade-in-up" style="opacity: 0;">
          <div class="decorative-line"></div>
          <p class="text-salon-gold font-medium tracking-widest uppercase text-sm">
            Friseur in Hollenstedt
          </p>
        </div>

        <h1 class="text-5xl sm:text-6xl md:text-7xl font-display font-semibold leading-tight
                    text-salon-dark animate-fade-in-up animate-delay-100" style="opacity: 0;">
          Salon<br />
          <span class="text-salon-gold italic">Dueball</span>
        </h1>

        <p class="text-lg md:text-xl text-warm-600 max-w-lg leading-relaxed
                  animate-fade-in-up animate-delay-200" style="opacity: 0;">
          Kreative Stylings, meisterhafte Colorationen und pers&ouml;nliche Beratung &ndash;
          seit 2013 Ihr Salon f&uuml;r perfekte Haarpflege und neueste Trends.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up animate-delay-300" style="opacity: 0;">
          <a
            href="https://connect.shore.com/bookings/friseur-christina-aldag/services?locale=de"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary text-base"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Termin buchen
          </a>
          <a href="#leistungen" class="btn-outline text-base">
            Unsere Leistungen
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="flex items-center gap-8 pt-4 animate-fade-in-up animate-delay-400" style="opacity: 0;">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-salon-gold" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span class="text-sm text-warm-600">Meisterbetrieb</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-salon-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm text-warm-600">Seit 2013</span>
          </div>
        </div>
      </div>

      <!-- Visual Element -->
      <div class="hidden lg:flex justify-center items-center animate-fade-in-up animate-delay-200" style="opacity: 0;">
        <div class="relative">
          <!-- Abstract salon illustration -->
          <div class="w-[400px] h-[500px] rounded-[2rem] bg-gradient-to-br from-warm-200 via-warm-100 to-salon-cream
                      border border-warm-200 shadow-2xl shadow-warm-200/50 overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="text-center space-y-6 p-8">
                <div class="w-24 h-24 mx-auto rounded-full bg-salon-gold/20 flex items-center justify-center">
                  <svg class="w-12 h-12 text-salon-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                          d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div class="space-y-3">
                  <p class="font-display text-3xl font-semibold text-salon-dark">Willkommen</p>
                  <div class="w-12 h-0.5 bg-salon-gold mx-auto"></div>
                  <p class="font-display text-lg text-warm-500 italic">
                    Wo Stil auf<br />Pers&ouml;nlichkeit trifft
                  </p>
                </div>
                <!-- Decorative scissors icon -->
                <div class="pt-4">
                  <svg class="w-16 h-16 mx-auto text-salon-gold/40" viewBox="0 0 64 64" fill="currentColor">
                    <path d="M20 12c-4.4 0-8 3.6-8 8s3.6 8 8 8c1.8 0 3.5-.6 4.9-1.7L32 32l-7.1 5.7c-1.4-1-3.1-1.7-4.9-1.7-4.4 0-8 3.6-8 8s3.6 8 8 8 8-3.6 8-8c0-1.8-.6-3.5-1.7-4.9L32 34l22-17h-8L32 28 20.7 18.3c1-1.4 1.7-3.1 1.7-4.9-.4-4.8-4-8.4-8.4-8.4zM20 24c-2.2 0-4-1.8-4-4s1.8-4 4-4 4 1.8 4 4-1.8 4-4 4zm0 28c-2.2 0-4-1.8-4-4s1.8-4 4-4 4 1.8 4 4-1.8 4-4 4zM46 34h8L32 49.4 29.2 47 46 34z"/>
                  </svg>
                </div>
              </div>
            </div>
          </div>
          <!-- Decorative floating elements -->
          <div class="absolute -top-6 -right-6 w-20 h-20 rounded-full bg-salon-gold/20 blur-sm"></div>
          <div class="absolute -bottom-4 -left-4 w-16 h-16 rounded-full bg-salon-rose/20 blur-sm"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <a href="#leistungen" class="text-warm-400 hover:text-salon-gold transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>
